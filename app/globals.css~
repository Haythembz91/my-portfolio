.projectCard{
    text-decoration: none;
    position: relative;
    background-color: #fff;
}

.glow {
  transition: box-shadow 0.3s ease;
}

.glow:hover {
  box-shadow: 0 0 20px 5px rgba(56, 55, 55, 0.6);
}

.textShadow{
  text-shadow: 2px 2px 4px #000, -2px -2px 4px #fff, 0 0 20px #2c2b2b ;
}

