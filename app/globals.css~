.headshot {
    width: 300px;
    height: 300px;
    object-fit: cover;

    /* Initial Shadow: Subtle dark grey/black glow */
    box-shadow: 0 0 25px rgba(0, 0, 0, 0.5),
    0 0 50px rgba(100, 100, 100, 0.2);

    animation: morphAndGlow 10s infinite alternate ease-in-out;

    /* Subtle grey border */
    border: 1px solid rgba(150, 150, 150, 0.3);
}

@keyframes morphAndGlow {
    0% {
        border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
        box-shadow: 0 0 25px rgba(0, 0, 0, 0.4);
        transform: scale(1);
    }
    50% {
        border-radius: 40% 60% 70% 30% / 40% 70% 30% 60%;
        /* Mid-point: Stronger grey "aura" */
        box-shadow: 0 0 45px rgba(80, 80, 80, 0.6),
        0 0 80px rgba(0, 0, 0, 0.3);
        transform: scale(1.02);
    }
    100% {
        border-radius: 50% 50% 33% 67% / 55% 27% 73% 45%;
        box-shadow: 0 0 25px rgba(50, 50, 50, 0.4);
        transform: scale(1);
    }
}